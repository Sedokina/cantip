# dependencies
node_modules/

# build output
build/
.cache/

# engine build output (regenerated by build.js / prepublish)
packages/cantip/dist/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# environment variables
.env
.env.production

# macOS-specific files
.DS_Store

# ── Per-project generated artifacts (regenerated by `cantip generate`).
#    `**/` so they match at ANY depth.
**/content/
**/public/pagefind/

# Generated manifests in example/user projects (ignore the whole dir).
examples/*/app/generated/

# Engine generated dir: ignore CONTENTS (not the dir) so the seed-module
# negations below take effect — git can't re-include a file under an ignored
# DIRECTORY, only under ignored contents. content.json is NOT committed (it's
# regenerated by `cantip generate` before every build/dev); ui.ts + site.json
# are committed seeds so the engine typechecks / boots pre-generate.
packages/cantip/app/generated/*
!packages/cantip/app/generated/ui.ts
!packages/cantip/app/generated/site.json

# editor
.idea/
