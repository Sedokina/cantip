{
  "name": "kantip-workspace",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "Workspace for the kantip docs engine and its scaffolder.",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "postinstall": "npm run build -w kantip",
    "build:engine": "npm run build -w kantip",
    "build:starter": "npm run build -w examples/starter",
    "dev:starter": "npm run dev -w examples/starter",
    "typecheck": "npm run typecheck -w kantip",
    "release": "npm publish -w kantip && npm publish -w create-kantip"
  },
  "engines": {
    "node": ">=20"
  }
}
