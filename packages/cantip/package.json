{
  "name": "cantip",
  "type": "module",
  "version": "0.6.2",
  "description": "Config-driven Remix documentation site engine — ingest Obsidian/markdown vaults, build an SSR docs site. \"How (to)\" in Kyrgyz.",
  "keywords": [
    "documentation",
    "docs",
    "remix",
    "obsidian",
    "markdown",
    "static-site",
    "ssr",
    "docs-site"
  ],
  "license": "MIT",
  "author": "Sedokina",
  "homepage": "https://github.com/Sedokina/cantip#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sedokina/cantip.git",
    "directory": "packages/cantip"
  },
  "bugs": {
    "url": "https://github.com/Sedokina/cantip/issues"
  },
  "bin": {
    "cantip": "cli.js"
  },
  "exports": {
    "./config": {
      "types": "./dist/types/app/lib/config/schema.d.ts",
      "default": "./dist/config.mjs"
    },
    "./vite": {
      "types": "./dist/types/src/vite/plugin.d.ts",
      "default": "./dist/vite.mjs"
    },
    "./root": {
      "types": "./dist/types/app/root.d.ts",
      "default": "./app/root.tsx"
    },
    "./root.server": {
      "types": "./dist/types/app/root.server.d.ts",
      "default": "./app/root.server.ts"
    },
    "./routes/doc": {
      "types": "./dist/types/app/routes/$.d.ts",
      "default": "./app/routes/$.tsx"
    },
    "./routes/doc.server": {
      "types": "./dist/types/app/routes/doc.server.d.ts",
      "default": "./app/routes/doc.server.ts"
    },
    "./routes/home": {
      "types": "./dist/types/app/routes/_index.d.ts",
      "default": "./app/routes/_index.tsx"
    },
    "./entry.server": {
      "types": "./dist/types/app/entry.server.d.ts",
      "default": "./app/entry.server.tsx"
    },
    "./entry.client": "./app/entry.client.tsx",
    "./components": {
      "types": "./dist/types/app/components/index.d.ts",
      "default": "./app/components/index.ts"
    },
    "./core": {
      "types": "./dist/types/app/lib/core.d.ts",
      "default": "./app/lib/core.ts"
    },
    "./source": {
      "types": "./dist/types/src/source/index.d.ts",
      "default": "./src/source/index.ts"
    },
    "./styles.css": "./app/styles/tailwind.css",
    "./package.json": "./package.json"
  },
  "files": [
    "app",
    "scripts",
    "src",
    "dist",
    "cli.js",
    "components.json",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "node build.js",
    "prepublishOnly": "node build.js",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@remix-run/node": "^2.15.0",
    "@remix-run/react": "^2.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "pagefind": "^1.5.2",
    "rehype-mermaid": "^2.1.0"
  },
  "peerDependenciesMeta": {
    "pagefind": {
      "optional": true
    },
    "rehype-mermaid": {
      "optional": true
    }
  },
  "dependencies": {
    "@headless-tree/core": "^1.7.0",
    "@headless-tree/react": "^1.7.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "isbot": "^5.1.0",
    "json-canvas-viewer": "^4.3.2",
    "katex": "^0.16.11",
    "lucide-react": "^1.17.0",
    "react-sticky-box": "^2.0.5",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.15.0",
    "@remix-run/node": "^2.15.0",
    "@remix-run/react": "^2.15.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "decode-uri-component": "^0.4.1",
    "github-slugger": "^2.0.0",
    "hast-util-to-html": "^9.0.5",
    "is-absolute-url": "^5.0.0",
    "mdast-util-find-and-replace": "^3.0.2",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-to-hast": "^13.2.1",
    "nanoid": "^5.1.11",
    "pagefind": "^1.5.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rehype": "^13.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-mermaid": "^2.1.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-breaks": "^4.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "tinyglobby": "^0.2.10",
    "tsc-alias": "^1.8.17",
    "typescript": "^5.6.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vfile": "^6.0.3",
    "vite": "^5.4.0",
    "yaml": "^2.9.0"
  },
  "engines": {
    "node": ">=20"
  }
}
